{
  "compilerOptions": {
    "target": "ES6",
    "module": "ESNext",
    "outDir": "./assets",
    "rootDir": "./assets",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["es2017", "dom"]
  },
  "include": ["assets/**/*.ts"],
  "exclude": ["node_modules"]
}
